{
  "name": "wa-flow-builder-preview",
  "displayName": "WhatsApp Flow Builder Preview",
  "description": "Live preview for WhatsApp Flow Builder inside VS Code",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Preview"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onCommand:wa-flow.preview",
    "onCommand:wa-flow.previewSide"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wa-flow.preview",
        "title": "Preview WhatsApp Flow",
        "icon": "$(open-preview)",
        "category": "WhatsApp Flow"
      },
      {
        "command": "wa-flow.previewSide",
        "title": "Preview in Side Panel",
        "icon": "$(layout-sidebyside)",
        "category": "WhatsApp Flow"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "wa-flow.preview",
          "when": "resourceLangId == javascript && resourceFilename =~ /.*\\.(flow|screen)\\.js$/",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "wa-flow.preview",
          "when": "resourceLangId == javascript && resourceFilename =~ /.*\\.(flow|screen)\\.js$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "wa-flow.preview",
          "when": "resourceLangId == javascript && resourceFilename =~ /.*\\.(flow|screen)\\.js$/"
        },
        {
          "command": "wa-flow.previewSide",
          "when": "resourceLangId == javascript && resourceFilename =~ /.*\\.(flow|screen)\\.js$/"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "waFlowPreview",
          "name": "WhatsApp Flow Preview",
          "when": "resourceLangId == javascript && resourceFilename =~ /.*\\.(flow|screen)\\.js$/"
        }
      ]
    },
    "configuration": {
      "title": "WhatsApp Flow Builder",
      "properties": {
        "waFlow.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh preview on file changes"
        },
        "waFlow.previewPort": {
          "type": "number",
          "default": 3000,
          "description": "Port for preview server"
        },
        "waFlow.theme": {
          "type": "string",
          "enum": ["whatsapp", "light", "dark"],
          "default": "whatsapp",
          "description": "Preview theme"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "ws": "^8.13.0"
  }
}
