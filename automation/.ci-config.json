{
  "nodeVersion": "18.x",
  "cacheDependencies": true,
  "runSecurityAudit": true,
  "generateArtifacts": true,
  "notifyOnFailure": true,
  "parallelJobs": 4,
  "timeoutMinutes": 30,
  "environment": {
    "NODE_ENV": "test"
  },
  "qualityGates": {
    "performance": {
      "maxLoadTime": 2000,
      "maxComplexity": 0.8
    },
    "coverage": {
      "minCoverage": 80
    },
    "bundleSize": {
      "maxSize": 1048576
    }
  },
  "notifications": {
    "slack": {
      "enabled": false,
      "webhook": ""
    },
    "email": {
      "enabled": false,
      "recipients": []
    }
  }
}
